{
  "info": {
    "name": "Carsharing API",
    "description": "REST API каршеринга.\n\n1. Environment: baseUrl (https://localhost:8443), authUsername, authPassword, userPassword\n2. Регистрация — POST /register (первый = ADMIN)\n3. JWT: POST /auth/login → accessToken и refreshToken сохраняются автоматически\n4. Защищённые запросы используют Bearer {{accessToken}}\n5. POST /auth/refresh — обновление пары токенов\n\nTLS: для самоподписанного сертификата отключите Settings → SSL certificate verification.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "https://localhost:8443", "type": "string"},
    {"key": "authUsername", "value": "", "type": "string"},
    {"key": "authPassword", "value": "", "type": "string"},
    {"key": "userPassword", "value": "", "type": "string"},
    {"key": "accessToken", "value": "", "type": "string"},
    {"key": "refreshToken", "value": "", "type": "string"},
    {"key": "oldRefreshToken", "value": "", "type": "string"}
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {"key": "token", "value": "{{accessToken}}", "type": "string"}
    ]
  },
  "item": [
    {
      "name": "0. Регистрация",
      "item": [
        {
          "name": "Регистрация (первый = ADMIN)",
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Админ\",\n  \"lastName\": \"Системы\",\n  \"email\": \"admin@carsharing.ru\",\n  \"username\": \"admin\",\n  \"password\": \"{{authPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/register"
          }
        },
        {
          "name": "Регистрация пользователя (USER)",
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Иван\",\n  \"lastName\": \"Петров\",\n  \"email\": \"ivan@mail.ru\",\n  \"username\": \"ivan\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/register"
          }
        }
      ]
    },
    {
      "name": "1. JWT Аутентификация",
      "description": "Сценарий: login → secure-test → refresh → повторный refresh (ошибка) → sessions",
      "item": [
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('accessToken', json.accessToken);",
                  "    pm.environment.set('refreshToken', json.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{authUsername}}\",\n  \"password\": \"{{authPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "GET /debug/secure-test (с access-токеном)",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}]},
            "method": "GET",
            "url": "{{baseUrl}}/debug/secure-test"
          }
        },
        {
          "name": "POST /auth/refresh",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('oldRefreshToken', pm.environment.get('refreshToken') || '');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('accessToken', json.accessToken);",
                  "    pm.environment.set('refreshToken', json.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "POST /auth/refresh (старый токен — ожидается 403)",
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{oldRefreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "GET /debug/sessions (статусы в БД)",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}]},
            "method": "GET",
            "url": "{{baseUrl}}/debug/sessions"
          }
        }
      ]
    },
    {
      "name": "2. Полный сценарий",
      "description": "Создать авто → пользователя → начать поездку → завершить → оплатить",
      "auth": {
        "type": "bearer",
        "bearer": [
          {"key": "token", "value": "{{accessToken}}", "type": "string"}
        ]
      },
      "item": [
        {
          "name": "Создать автомобиль",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"brand\": \"Lada\",\n  \"model\": \"Vesta\",\n  \"plateNumber\": \"А123ВС77\"\n}"},
            "url": "{{baseUrl}}/cars"
          }
        },
        {
          "name": "Создать пользователя",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"firstName\": \"Иван\",\n  \"lastName\": \"Петров\",\n  \"email\": \"ivan@mail.ru\",\n  \"username\": \"ivan\",\n  \"password\": \"{{userPassword}}\"\n}"},
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Начать поездку",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"carId\": 1,\n  \"startTime\": \"10.03.2026 10:00\"\n}"},
            "url": "{{baseUrl}}/rides"
          }
        },
        {
          "name": "Завершить поездку",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"endTime\": \"10.03.2026 11:30\",\n  \"distance\": 25.5\n}"},
            "url": "{{baseUrl}}/rides/1/end"
          }
        },
        {
          "name": "Оплатить поездку",
          "request": {"method": "POST", "url": "{{baseUrl}}/rides/1/pay"}
        },
        {
          "name": "Доход пользователя",
          "request": {"method": "GET", "url": "{{baseUrl}}/users/1/income"}
        }
      ]
    },
    {
      "name": "Автомобили",
      "auth": {
        "type": "bearer",
        "bearer": [
          {"key": "token", "value": "{{accessToken}}", "type": "string"}
        ]
      },
      "item": [
        {"name": "Все автомобили", "request": {"method": "GET", "url": "{{baseUrl}}/cars"}},
        {"name": "Все (только доступные)", "request": {"method": "GET", "url": "{{baseUrl}}/cars?available=true"}},
        {"name": "Доступные", "request": {"method": "GET", "url": "{{baseUrl}}/cars/available"}},
        {"name": "По ID", "request": {"method": "GET", "url": "{{baseUrl}}/cars/1"}},
        {
          "name": "Создать",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"brand\": \"Lada\",\n  \"model\": \"Vesta\",\n  \"plateNumber\": \"А123ВС77\"\n}"},
            "url": "{{baseUrl}}/cars"
          }
        },
        {
          "name": "Обновить",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"brand\": \"Lada\",\n  \"model\": \"Vesta SW\",\n  \"plateNumber\": \"А123ВС77\",\n  \"available\": true\n}"},
            "url": "{{baseUrl}}/cars/1"
          }
        },
        {"name": "Удалить", "request": {"method": "DELETE", "url": "{{baseUrl}}/cars/1"}}
      ]
    },
    {
      "name": "Пользователи",
      "auth": {
        "type": "bearer",
        "bearer": [
          {"key": "token", "value": "{{accessToken}}", "type": "string"}
        ]
      },
      "item": [
        {"name": "Все пользователи", "request": {"method": "GET", "url": "{{baseUrl}}/users"}},
        {"name": "По ID", "request": {"method": "GET", "url": "{{baseUrl}}/users/1"}},
        {"name": "Доход пользователя", "request": {"method": "GET", "url": "{{baseUrl}}/users/1/income"}},
        {
          "name": "Создать",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"firstName\": \"Иван\",\n  \"lastName\": \"Петров\",\n  \"email\": \"ivan@mail.ru\",\n  \"username\": \"ivan\",\n  \"password\": \"{{userPassword}}\"\n}"},
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Обновить",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"firstName\": \"Иван\",\n  \"lastName\": \"Петров\",\n  \"email\": \"ivan@yandex.ru\",\n  \"username\": \"ivan\"\n}"},
            "url": "{{baseUrl}}/users/1"
          }
        },
        {"name": "Удалить", "request": {"method": "DELETE", "url": "{{baseUrl}}/users/1"}}
      ]
    },
    {
      "name": "Поездки",
      "auth": {
        "type": "bearer",
        "bearer": [
          {"key": "token", "value": "{{accessToken}}", "type": "string"}
        ]
      },
      "item": [
        {"name": "Все поездки", "request": {"method": "GET", "url": "{{baseUrl}}/rides"}},
        {"name": "По ID", "request": {"method": "GET", "url": "{{baseUrl}}/rides/1"}},
        {
          "name": "Начать",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"carId\": 1,\n  \"startTime\": \"10.03.2026 10:00\"\n}"},
            "url": "{{baseUrl}}/rides"
          }
        },
        {
          "name": "Завершить",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"endTime\": \"10.03.2026 11:30\",\n  \"distance\": 25.5\n}"},
            "url": "{{baseUrl}}/rides/1/end"
          }
        },
        {"name": "Оплатить", "request": {"method": "POST", "url": "{{baseUrl}}/rides/1/pay"}},
        {"name": "Удалить", "request": {"method": "DELETE", "url": "{{baseUrl}}/rides/1"}}
      ]
    },
    {
      "name": "Платежи",
      "auth": {
        "type": "bearer",
        "bearer": [
          {"key": "token", "value": "{{accessToken}}", "type": "string"}
        ]
      },
      "item": [
        {"name": "Все платежи", "request": {"method": "GET", "url": "{{baseUrl}}/payments"}},
        {"name": "По ID", "request": {"method": "GET", "url": "{{baseUrl}}/payments/1"}},
        {
          "name": "Создать",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"rideId\": 1\n}"},
            "url": "{{baseUrl}}/payments"
          }
        },
        {"name": "Отметить оплаченным", "request": {"method": "PUT", "url": "{{baseUrl}}/payments/1/pay"}},
        {"name": "Удалить", "request": {"method": "DELETE", "url": "{{baseUrl}}/payments/1"}}
      ]
    }
  ]
}
