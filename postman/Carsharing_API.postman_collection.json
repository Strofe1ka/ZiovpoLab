            "body": {"mode": "raw", "raw": "{\n  \"firstName\": \"Иван\",\n  \"lastName\": \"Петров\",\n  \"email\": \"ivan.petrov@yandex.ru\",\n  \"username\": \"ivan\"\n}"},
            "url": "https://localhost:8443/users/1"
          }
        },
        {"name": "Удалить пользователя", "request": {"method": "DELETE", "url": "https://localhost:8443/users/1"}}
      ]
    },
    {
      "name": "Поездки",
      "item": [
        {
          "name": "Начать поездку",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"carId\": 1,\n  \"startTime\": \"28.02.2025 10:00\"\n}"},
