            "url": "https://localhost:8443/cars"
          }
        },
        {"name": "Получить все автомобили", "request": {"method": "GET", "url": "https://localhost:8443/cars"}},
        {"name": "Получить доступные автомобили", "request": {"method": "GET", "url": "https://localhost:8443/cars/available"}},
        {"name": "Получить автомобиль по ID", "request": {"method": "GET", "url": "https://localhost:8443/cars/1"}},
        {
          "name": "Обновить автомобиль",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"brand\": \"Lada\",\n  \"model\": \"Vesta SW\",\n  \"plateNumber\": \"А123ВС77\",\n  \"available\": true\n}"},
            "url": "https://localhost:8443/cars/1"
          }
        },
        {"name": "Удалить автомобиль", "request": {"method": "DELETE", "url": "https://localhost:8443/cars/1"}}
      ]
    },
    {
