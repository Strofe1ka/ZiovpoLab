        {"name": "Получить всех пользователей", "request": {"method": "GET", "url": "https://localhost:8443/users"}},
        {"name": "Получить пользователя по ID", "request": {"method": "GET", "url": "https://localhost:8443/users/1"}},
        {"name": "Получить доход пользователя", "request": {"method": "GET", "url": "https://localhost:8443/users/1/income"}},
        {
          "name": "Обновить пользователя",
          "request": {
            "method": "PUT",
