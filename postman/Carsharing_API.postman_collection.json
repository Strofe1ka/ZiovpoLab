{
  "info": {
    "name": "Carsharing API (Россия)",
    "description": "CRUD и бизнес-операции каршеринга. Spring Security: Basic Auth. Создайте Environment с переменными authUsername, authPassword, userPassword.\n\nTLS: для самоподписанного сертификата отключите Settings → SSL certificate verification.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "authUsername", "value": "", "type": "string"},
    {"key": "authPassword", "value": "", "type": "string"},
    {"key": "userPassword", "value": "", "type": "string"}
  ],
  "auth": {
    "type": "basic",
    "basic": [
      {"key": "username", "value": "{{authUsername}}", "type": "string"},
      {"key": "password", "value": "{{authPassword}}", "type": "string"}
    ]
  },
  "item": [
    {
      "name": "Регистрация и аутентификация",
      "item": [
        {
          "name": "Регистрация (без авторизации)",
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"firstName\": \"Админ\",\n  \"lastName\": \"Системы\",\n  \"email\": \"admin@carsharing.ru\",\n  \"username\": \"admin\",\n  \"password\": \"{{authPassword}}\"\n}"},
            "url": "https://localhost:8443/register"
          }
        },
        {
          "name": "Регистрация пользователя (USER)",
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"firstName\": \"Иван\",\n  \"lastName\": \"Петров\",\n  \"email\": \"ivan.petrov@mail.ru\",\n  \"username\": \"ivan\",\n  \"password\": \"{{userPassword}}\"\n}"},
            "url": "https://localhost:8443/register"
          }
        }
      ]
    },
    {
      "name": "Полный сценарий",
      "description": "Создание сущностей → старт поездки → завершение → оплата → проверка",
      "item": [
        {
          "name": "1. Создать автомобиль",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"brand\": \"Lada\",\n  \"model\": \"Vesta\",\n  \"plateNumber\": \"А123ВС77\"\n}"},
            "url": "https://localhost:8443/cars"
          }
        },
        {
          "name": "2. Создать пользователя (ADMIN)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"firstName\": \"Иван\",\n  \"lastName\": \"Петров\",\n  \"email\": \"ivan.petrov@mail.ru\",\n  \"username\": \"ivan\",\n  \"password\": \"{{userPassword}}\"\n}"},
            "url": "https://localhost:8443/users"
          }
        },
        {
          "name": "3. Начать поездку",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"carId\": 1,\n  \"startTime\": \"28.02.2025 10:00\"\n}"},
            "url": "https://localhost:8443/rides"
          }
        },
        {
          "name": "4. Завершить поездку",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"endTime\": \"28.02.2025 11:30\",\n  \"distance\": 25.5\n}"},
            "url": "https://localhost:8443/rides/1/end"
          }
        },
        {
          "name": "5. Оплатить поездку",
          "request": {"method": "POST", "url": "https://localhost:8443/rides/1/pay"}
        },
        {
          "name": "6. Проверить доход пользователя",
          "request": {"method": "GET", "url": "https://localhost:8443/users/1/income"}
        },
        {
          "name": "7. Список доступных авто",
          "request": {"method": "GET", "url": "https://localhost:8443/cars/available"}
        }
      ]
    },
    {
      "name": "Автомобили",
      "item": [
        {
          "name": "Создать автомобиль",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"brand\": \"Lada\",\n  \"model\": \"Vesta\",\n  \"plateNumber\": \"А123ВС77\"\n}"},
            "url": "https://localhost:8443/cars"
          }
        },
        {
          "name": "Создать автомобиль (Hyundai)",
