# Скопируйте в .env и заполните своими значениями.
# Файл .env не попадает в git.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=carsharing
DB_PASSWORD=your_password_here

# TLS (после генерации сертификатов: scripts/generate-certificates.ps1)
# Пароль берётся из certs/.keystore-password
SSL_KEY_STORE_PATH=file:./certs/carsharing-keystore.p12
SSL_KEY_STORE_PASSWORD=your_keystore_password_from_certs_folder
