# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/ziovpo
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT secrets and TTLs
JWT_ACCESS_SECRET=replace_with_base64_access_secret
JWT_REFRESH_SECRET=replace_with_base64_refresh_secret
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# HTTPS
SSL_ENABLED=false
SSL_KEY_STORE=
SSL_KEY_STORE_PASSWORD=
SSL_KEY_ALIAS=

# License tickets (ЭЦП): PKCS12 keystore; if empty, an ephemeral RSA key is generated (dev only)
LICENSE_TICKET_TTL_SECONDS=300
LICENSE_SIGNING_KEYSTORE=
LICENSE_SIGNING_KEYSTORE_PASSWORD=
LICENSE_SIGNING_KEY_ALIAS=license-signing
LICENSE_SIGNING_KEY_PASSWORD=
